<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="C971project.Views.AssessmentEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Assessment">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Assessment Title" />
            <Entry Text="{Binding Title}" Placeholder="e.g., Final Exam" />

            <Label Text="Type" />
            <Picker SelectedItem="{Binding Type}">
                <Picker.Items>
                    <x:String>Objective</x:String>
                    <x:String>Performance</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Start Date" />
            <DatePicker Date="{Binding StartDate}" />

            <Label Text="End Date" />
            <DatePicker Date="{Binding EndDate}" />
            <Label Text="Assessment Notifications" FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="12">
                <CheckBox IsChecked="{Binding NotifyStart}" />
                <Label Text="Notify on Start Date" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <CheckBox IsChecked="{Binding NotifyEnd}" />
                <Label Text="Notify on End Date" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Text="Save" Command="{Binding SaveCommand}" />
            <Button Text="Delete" Command="{Binding DeleteCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
