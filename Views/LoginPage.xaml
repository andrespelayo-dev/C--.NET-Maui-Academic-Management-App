<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="C971project.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Login">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Label
                FontAttributes="Bold"
                FontSize="28"
                HorizontalOptions="Center"
                Text="Academic Management App" />

            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="Please sign in to continue" />

            <Entry
                x:Name="UsernameEntry"
                Placeholder="Username" />

            <Entry
                x:Name="PasswordEntry"
                IsPassword="True"
                Placeholder="Password" />

            <Button
                Clicked="OnLoginClicked"
                Text="Login" />

            <Label
    FontSize="15"
    HorizontalOptions="Center"
    Opacity="0.85">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Test Username: " />
                        <Span Text="apelayo" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label
    FontSize="15"
    HorizontalOptions="Center"
    Opacity="0.85">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Test Password: " />
                        <Span Text="testwgu" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>